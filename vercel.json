{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "^/$", "dest": "/api/index.php?route=login.php" },
    { "src": "^/admin/?$", "dest": "/api/index.php?route=admin/login.php" },
    { "src": "^/admin/(.*)$", "dest": "/api/index.php?route=admin/$1" },
    { "src": "^/src/services/api/(.*)$", "dest": "/api/index.php?route=api/$1" },
    { "src": "^/(.*)$", "dest": "/api/index.php?route=$1" }
  ]
}
