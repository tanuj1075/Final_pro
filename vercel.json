{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/src/assets/(.*)", "dest": "/src/assets/$1" },
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/index.php?route=api/$1" },
    { "src": "/admin/(.*)", "dest": "/api/index.php?route=admin/$1" },
    { "src": "/(.*)", "dest": "/api/index.php?route=$1" }
  ]
}
