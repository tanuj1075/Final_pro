{
  "name": "final-pro-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "database"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "check": "npm --workspace backend run check && npm --workspace frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
